{
  "version": 2,
  "functions": {
    "api/scores.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/scores",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=180, s-maxage=180" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}